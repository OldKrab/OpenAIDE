OPENAIDE_WEB_INSTANCE_LABEL=Target
OPENAIDE_WEB_TITLE="OpenAIDE Target"
OPENAIDE_WEB_ALLOWED_HOSTS=localhost,127.0.0.1
OPENAIDE_WEB_PORT=5574
OPENAIDE_WEB_VITE_PORT=5573
OPENAIDE_WEB_PROTOTYPE_PORT=5572
OPENAIDE_WEB_STATE_ROOT=$repo_root/.openaide-web-target/state
OPENAIDE_WEB_RUNTIME_ROOT=$repo_root/.openaide-web-target/runtime
OPENAIDE_WEB_STATIC_ROOT=$repo_root/.openaide-web-target/static
OPENAIDE_WEB_PROJECT_ROOTS=$repo_root
OPENAIDE_WEB_PID_FILE=/tmp/openaide-web-target-5574.pid
OPENAIDE_WEB_LOG_FILE=/tmp/openaide-web-target-5574.log
OPENAIDE_WEB_DAEMON=systemd
OPENAIDE_WEB_SYSTEMD_UNIT=openaide-web-target-5574
OPENAIDE_WEB_BUILD=1
OPENAIDE_WEB_DEBUG_BUILD=1
